{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2024",
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": false,
    "sourceRoot": "src",
    "baseUrl": "src",
    "outDir": "dist",
    "strict": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "lib": [
      "es2024",
      "DOM.Iterable",
      "DOM"
    ]
  },
  "include": [
    "src/index.ts",
    "src/shared/**/*",
    ".eslintrc.js",
    "webpack.config.js"
  ],
  "exclude": [
    "src/workers/**/*"
  ]
}
