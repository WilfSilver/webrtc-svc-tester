{
  "compilerOptions": {
    "module": "esnext",
    "target": "es2024",
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitReturns": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": false,
    "sourceRoot": "src",
    "baseUrl": ".",
    "outDir": "dist",
    "strict": true,
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "lib": ["es2024", "DOM.Iterable", "DOM"],
    "paths": {
      "@src/*": ["src/*"]
    }
  },
  "include": [
    "src/shared/**/*",
    "src/dom/**/*",
    "src/lib/**/*",
    "webpack.config.js"
  ],
  "exclude": ["src/workers/**/*"]
}
